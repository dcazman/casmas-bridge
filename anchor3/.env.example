# Required
ENCRYPTION_KEY=changeme-32-char-random-string
ANTHROPIC_API_KEY=sk-ant-...

# LLM (Ollama default; set USE_OLLAMA=false to use Anthropic directly)
USE_OLLAMA=true
OLLAMA_URL=http://192.168.50.50:11434

# Outbound email (reminders / digest alerts)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ALERT_EMAIL=
ALERT_EMAIL2=

# Inbound email (send notes to anchor@thecasmas.com)
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
ANCHOR_INBOUND=anchor@thecasmas.com

# Weather (Tempest station — leave blank to disable)
TEMPEST_TOKEN=
